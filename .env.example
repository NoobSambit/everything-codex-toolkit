# Optional environment variables for Everything Codex Toolkit examples.
#
# Copy to .env only if you need local environment variables.
# Never commit real secrets.

# OpenAI / Codex API usage where required by your Codex client.
OPENAI_API_KEY=

# GitHub MCP server.
GITHUB_TOKEN=

# Exa MCP server, if enabled.
EXA_API_KEY=

# Jira prompt or Jira MCP usage, if enabled.
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Optional default branch used by local scripts or examples.
DEFAULT_BASE_BRANCH=main
